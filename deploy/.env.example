# Copy to /opt/yammer/.env on the api VM. Secrets are pulled from Secret Manager by
# the VM startup script (vm-startup.sh) / the deploy step — do not commit real values.
API_IMAGE=europe-west1-docker.pkg.dev/yammer-order-app/yammer/api:latest
INSTANCE_CONNECTION_NAME=yammer-order-app:europe-west1:yammer-db
API_DOMAIN=api.example.com
DATABASE_USERNAME=yammer_app
DATABASE_PASSWORD=__from_secret_manager__
JWT_SECRET=__from_secret_manager__
BRIDGE_API_KEY=__from_secret_manager__
GCS_BUCKET=yammer-order-app-uploads
GCS_PROJECT_ID=yammer-order-app
